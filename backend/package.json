{
  "name": "outlook-policy-addin-backend",
  "version": "1.0.0",
  "description": "Backend service for Outlook recipient policy validation add-in",
  "main": "dist/index.js",
  "scripts": {
    "build":       "tsc",
    "start":       "node dist/index.js",
    "dev":         "ts-node-dev --respawn --transpile-only src/index.ts",
    "test":        "jest --runInBand --forceExit",
    "test:watch":  "jest --watch",
    "lint":        "eslint src test --ext .ts"
  },
  "dependencies": {
    "cors":    "^2.8.5",
    "express": "^4.18.2"
  },
  "devDependencies": {
    "@types/cors":       "^2.8.17",
    "@types/express":    "^4.17.21",
    "@types/jest":       "^29.5.12",
    "@types/node":       "^20.0.0",
    "jest":              "^29.7.0",
    "ts-jest":           "^29.1.4",
    "ts-node-dev":       "^2.0.0",
    "typescript":        "^5.4.0"
  },
  "jest": {
    "preset":        "ts-jest",
    "testEnvironment": "node",
    "roots":         ["<rootDir>/test"],
    "testMatch":     ["**/*.test.ts"]
  }
}
