<?xml version="1.0" encoding="UTF-8"?>
<OfficeApp
  xmlns="http://schemas.microsoft.com/office/appforoffice/1.1"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xmlns:bt="http://schemas.microsoft.com/office/officeappbasictypes/1.0"
  xmlns:mailappor="http://schemas.microsoft.com/office/mailappversionoverrides/1.0"
  xsi:type="MailApp">

  <!-- OfficeApp metadata -->
  <Id>a1b2c3d4-e5f6-7890-abcd-ef1234567890</Id>
  <Version>1.0.0.0</Version>
  <ProviderName>Contoso Insurance</ProviderName>
  <DefaultLocale>en-US</DefaultLocale>
  <DisplayName DefaultValue="Recipient Policy Validator" />
  <Description DefaultValue="Validates that email recipients are authorised policy holders for every attachment." />
  <IconUrl DefaultValue="https://localhost:3000/assets/icon-80.png" />
  <HighResolutionIconUrl DefaultValue="https://localhost:3000/assets/icon-80.png" />
  <SupportUrl DefaultValue="https://localhost:3000" />


  <!-- Hosts: Outlook only -->
  <Hosts>
    <Host Name="Mailbox" />
  </Hosts>

  <!-- Requirement sets -->
  <Requirements>
    <Sets>
      <Set Name="Mailbox" MinVersion="1.5" />
    </Sets>
  </Requirements>


  <!-- Form factors (legacy, required for older Outlook clients) -->
  <FormSettings>
    <Form xsi:type="ItemRead">
      <DesktopSettings>
        <SourceLocation DefaultValue="https://localhost:3000/taskpane/taskpane.html" />
        <RequestedHeight>250</RequestedHeight>
      </DesktopSettings>
    </Form>
    <Form xsi:type="ItemEdit">
      <DesktopSettings>
        <SourceLocation DefaultValue="https://localhost:3000/taskpane/taskpane.html" />
      </DesktopSettings>
    </Form>
  </FormSettings>

  <!-- Permissions: ReadWriteItem needed to read Bcc in compose -->
  <Permissions>ReadWriteItem</Permissions>

  <!-- Rule: activation condition for older Outlook clients (fallback for VersionOverrides).
       Activates on all message compose and read forms. -->
  <Rule xsi:type="RuleCollection" Mode="Or">
    <Rule xsi:type="ItemIs" ItemType="Message" FormType="Edit" />
    <Rule xsi:type="ItemIs" ItemType="Message" FormType="Read" />
  </Rule>

  <!-- Extension points: ribbon button in compose window -->
  <VersionOverrides xmlns="http://schemas.microsoft.com/office/mailappversionoverrides" xsi:type="VersionOverridesV1_0">
    <VersionOverrides xmlns="http://schemas.microsoft.com/office/mailappversionoverrides/1.1" xsi:type="VersionOverridesV1_1">

      <!-- SSO: Add WebApplicationInfo here once you have a real Azure App Registration.
           Example:
           <WebApplicationInfo>
             <Id>xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx</Id>
             <Resource>api://localhost:3000/xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx</Resource>
             <Scopes>
               <Scope>openid</Scope>
               <Scope>profile</Scope>
               <Scope>User.Read</Scope>
             </Scopes>
           </WebApplicationInfo>
      -->

      <Hosts>
        <Host xsi:type="MailHost">

          <!-- Desktop (Windows + Mac Outlook) -->
          <DesktopFormFactor>
            <FunctionFile resid="Commands.Url" />

            <!-- MessageCompose: compose new email -->
            <ExtensionPoint xsi:type="MessageComposeCommandSurface">
              <OfficeTab id="TabDefault">
                <Group id="Contoso.Group1">
                  <Label resid="GroupLabel" />
                  <Control xsi:type="Button" id="Contoso.ValidateBtn">
                    <Label resid="TaskpaneButton.Label" />
                    <Supertip>
                      <Title resid="TaskpaneButton.Label" />
                      <Description resid="TaskpaneButton.Tooltip" />
                    </Supertip>
                    <Icon>
                      <bt:Image size="16" resid="Icon.16x16" />
                      <bt:Image size="32" resid="Icon.32x32" />
                      <bt:Image size="80" resid="Icon.80x80" />
                    </Icon>
                    <!-- FunctionCommand: calls ValidateRecipients() in commands.ts -->
                    <Action xsi:type="ExecuteFunction">
                      <FunctionName>ValidateRecipients</FunctionName>
                    </Action>
                  </Control>
                </Group>
              </OfficeTab>
            </ExtensionPoint>

            <!-- MessageRead: read mode (for auditing already-sent mail) -->
            <ExtensionPoint xsi:type="MessageReadCommandSurface">
              <OfficeTab id="TabDefault">
                <Group id="Contoso.Group2">
                  <Label resid="GroupLabel" />
                  <Control xsi:type="Button" id="Contoso.ValidateBtnRead">
                    <Label resid="TaskpaneButton.Label" />
                    <Supertip>
                      <Title resid="TaskpaneButton.Label" />
                      <Description resid="TaskpaneButton.Tooltip" />
                    </Supertip>
                    <Icon>
                      <bt:Image size="16" resid="Icon.16x16" />
                      <bt:Image size="32" resid="Icon.32x32" />
                      <bt:Image size="80" resid="Icon.80x80" />
                    </Icon>
                    <Action xsi:type="ExecuteFunction">
                      <FunctionName>ValidateRecipients</FunctionName>
                    </Action>
                  </Control>
                </Group>
              </OfficeTab>
            </ExtensionPoint>

          </DesktopFormFactor>
        </Host>
      </Hosts>

      <!-- Shared resources -->
      <Resources>
        <bt:Images>
          <bt:Image id="Icon.16x16" DefaultValue="https://localhost:3000/assets/icon-16.png" />
          <bt:Image id="Icon.32x32" DefaultValue="https://localhost:3000/assets/icon-32.png" />
          <bt:Image id="Icon.80x80" DefaultValue="https://localhost:3000/assets/icon-80.png" />
        </bt:Images>
        <bt:Urls>
          <bt:Url id="Commands.Url" DefaultValue="https://localhost:3000/commands/commands.html" />
          <bt:Url id="Taskpane.Url"  DefaultValue="https://localhost:3000/taskpane/taskpane.html" />
        </bt:Urls>
        <bt:ShortStrings>
          <bt:String id="GroupLabel"             DefaultValue="Policy Tools" />
          <bt:String id="TaskpaneButton.Label"   DefaultValue="Validate Recipients" />
        </bt:ShortStrings>
        <bt:LongStrings>
          <bt:String id="TaskpaneButton.Tooltip" DefaultValue="Check that all recipients are authorised policy holders for every attachment." />
        </bt:LongStrings>
      </Resources>

    </VersionOverrides>
  </VersionOverrides>
</OfficeApp>
