{
  "name": "outlook-policy-addin",
  "version": "1.0.0",
  "description": "Outlook add-in for recipient policy validation",
  "scripts": {
    "build":       "webpack --mode production",
    "build:dev":   "webpack --mode development",
    "watch":       "webpack --mode development --watch",
    "start":       "webpack serve --mode development",
    "install-certs": "npx office-addin-dev-certs install --days 365",
    "validate-manifest": "npx office-addin-manifest validate manifest.xml",
    "lint":        "eslint src --ext .ts"
  },
  "dependencies": {
    "@microsoft/office-js": "^1.1.0"
  },
  "devDependencies": {
    "@types/office-js":          "^1.0.390",
    "@types/node":               "^20.0.0",
    "copy-webpack-plugin":       "^11.0.0",
    "css-loader":                "^6.0.0",
    "html-webpack-plugin":       "^5.0.0",
    "office-addin-dev-certs":    "^1.12.0",
    "office-addin-manifest":     "^1.0.0",
    "style-loader":              "^3.0.0",
    "ts-loader":                 "^9.0.0",
    "typescript":                "^5.4.0",
    "webpack":                   "^5.0.0",
    "webpack-cli":               "^5.0.0",
    "webpack-dev-server":        "^4.0.0"
  }
}
